{
  "manifest_version": 3,
  "name": "Cloud Navigator - Setup Guide",
  "version": "0.1.0",
  "description": "Intelligent guide for setting up cloud services based on your codebase",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://api.anthropic.com/*",
    "https://*.console.aws.amazon.com/*",
    "https://console.cloud.google.com/*",
    "https://portal.azure.com/*",
    "https://console.firebase.google.com/*",
    "https://dashboard.heroku.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cloud Navigator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://*.console.aws.amazon.com/*",
        "https://console.cloud.google.com/*",
        "https://portal.azure.com/*",
        "https://console.firebase.google.com/*",
        "https://dashboard.heroku.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.github.com https://api.anthropic.com"
  }
}
